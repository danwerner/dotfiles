[user]

[color]
	diff = auto
	status = auto
	branch = auto

[alias]
	co = checkout
	index = diff --cached
	amend = commit --amend -C HEAD

[apply]
	whitespace = nowarn

[push]
	default = current

[merge]
	conflictstyle = diff3

[gc]
	pruneexpire = 30 days

[credential]
	# Mac OS X only
	#helper = osxkeychain
